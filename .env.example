# ═══════════════════════════════════════════════════════════════
# Harang Backend 환경 변수 설정
# ═══════════════════════════════════════════════════════════════

# ── 필수 환경 변수 ──────────────────────────────────────────
# 이 값들은 반드시 설정해야 합니다. 설정하지 않으면 서버가 시작되지 않습니다.

# 데이터베이스 연결 URL
# 형식: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/harang"

# JWT 시크릿 키 (16자 이상의 랜덤 문자열 필수!)
# 생성 방법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ 프로덕션에서는 반드시 강력한 랜덤 키를 사용하세요!
JWT_SECRET="your-secret-key-here-change-this-in-production"

# ── 선택 환경 변수 (기본값 있음) ────────────────────────────

# JWT 토큰 만료 시간 (기본값: 7d)
JWT_EXPIRES_IN="7d"

# 서버 포트 (기본값: 8000)
PORT=8000

# 프론트엔드 URL (CORS 설정용, 기본값: http://localhost:3000)
CLIENT_URL="http://localhost:3000"

# Node 환경 (development | production | test, 기본값: development)
NODE_ENV="development"
