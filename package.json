{
  "name": "harang-backend",
  "version": "1.0.0",
  "description": "Harang 학교 소통 플랫폼 백엔드 API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "prisma studio",
    "setup": "npm install && npx prisma generate && npx prisma db push && tsx src/seed.ts",
    "generate-code": "tsx src/generate-teacher-code.ts",
    "list-codes": "tsx src/generate-teacher-code.ts list",
    "list-unused": "tsx src/generate-teacher-code.ts list unused",
    "delete-code": "tsx src/generate-teacher-code.ts delete"
  },
  "dependencies": {
    "@getbrevo/brevo": "^5.0.4",
    "@prisma/client": "5.15.0",
    "@types/socket.io": "^3.0.1",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.2.0",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemailer": "^8.0.8",
    "resend": "^6.16.0",
    "socket.io": "^4.8.3",
    "winston": "^3.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.0",
    "prisma": "5.15.0",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  }
}
